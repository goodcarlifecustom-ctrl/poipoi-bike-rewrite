# WordPress REST API
WP_USERNAME=your-wp-login-username
WP_APPLICATION_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

# WordPress REST APIのルートを指定する場合に設定
# 例:
# 正しい例:
# WP_REST_ROOT=https://poi-poi.co.jp/bike/
# WP_REST_ROOT=https://poi-poi.co.jp/bike/wp-json/
# 誤った例（create-wordpress-draft.mjs が wp/v2/{投稿タイプ} を付加するため指定しない）:
# WP_REST_ROOT=https://poi-poi.co.jp/bike/wp-json/wp/v2/
# WP_REST_ROOT=https://poi-poi.co.jp/bike/wp-json/wp/v2/posts
WP_REST_ROOT=

# 元記事取得時に検索する投稿タイプ候補。複数指定
WP_POST_TYPES=posts,pages

# WordPressへ新規下書きを作成する投稿タイプ。単一指定
WP_POST_TYPE=posts

# rendered = 実際に表示されるHTML
# raw = Gutenbergの編集元に近い本文。返ってこない環境ではrenderedにフォールバック
WP_CONTENT_MODE=rendered

# 短すぎるHTMLをエラーにする閾値
MIN_HTML_LENGTH=500
